# Copy this file to application-secrets.properties for local development ONLY.
# NEVER commit application-secrets.properties to version control.
# In production (Railway), set these as environment variables instead.

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=your-minimum-64-char-random-secret-string-here-change-this-now!
